# Anthropic API key — enables AI explanations and the chat assistant.
# Get one at https://console.anthropic.com → API Keys.
# Without it the app still works; AI features show a graceful fallback.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown). Explanations use the fast/cheap
# model; chat uses the smarter one. Note: only Sonnet/Opus models accept the
# "effort" parameter the chat path sends.
# AI_EXPLAIN_MODEL=claude-haiku-4-5
# AI_CHAT_MODEL=claude-sonnet-4-6
